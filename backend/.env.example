# ══════════════════════════════════════════════════════
#   MAYZER — Variables de entorno (plantilla)
#   Copia este archivo como .env y completa tus propios valores.
#   El archivo .env NUNCA debe subirse a Git (ver .gitignore).
# ══════════════════════════════════════════════════════

# ── Base de datos MySQL ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_mysql
DB_NAME=mayzer_db

# ── Cifrado de datos sensibles (aspirantes) ─────────
# Clave de 32+ caracteres usada para cifrar/descifrar numero_documento,
# email y telefono de los aspirantes (AES-256-CBC).
# OBLIGATORIA en producción (NODE_ENV=production); en desarrollo, si se
# omite, el sistema usa una clave de respaldo solo para pruebas locales.
ENCRYPTION_KEY=cambia_esto_por_una_clave_de_al_menos_32_caracteres

# ── JWT (autenticación) ─────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=15m

# ── Servidor ────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Frontend (CORS) ─────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Correo SMTP ─────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_correo@gmail.com
# Si usas Gmail, esto debe ser una "contraseña de aplicación" (no tu password normal):
# https://myaccount.google.com/apppasswords
MAIL_PASS=tu_contrasena_de_aplicacion
MAIL_FROM=MAYZER SENA <tu_correo@gmail.com>

# ── SENA ─────────────────────────────────────────────
SENA_NOMBRE=SENA Sede Palmira
SENA_DIRECCION=Palmira, Valle del Cauca, Colombia
