# ══════════════════════════════════════════════════════
#   MAYZER — Variables de entorno (ejemplo)
#   ⚠️  Este archivo es solo una plantilla
# ══════════════════════════════════════════════════════

# ── Base de datos MySQL ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=usuario_db
DB_PASSWORD=contraseña_db
DB_NAME=mayzer_db

# ── JWT (autenticación) ─────────────────────────────
JWT_SECRET=clave_secreta_jwt
JWT_EXPIRES_IN=15m

# ── Servidor ────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Frontend (CORS) ─────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Correo SMTP ─────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=usuario@gmail.com
MAIL_PASS=contraseña_app
MAIL_FROM="MAYZER SENA <usuario@gmail.com>"

# ── SENA ─────────────────────────────────────────────
SENA_NOMBRE=SENA Sede Palmira
SENA_DIRECCION=Palmira, Valle del Cauca, Colombia
